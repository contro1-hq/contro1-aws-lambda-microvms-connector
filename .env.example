# Contro1 / CENTCOM
CONTRO1_API_KEY=cc_live_your_key
CONTRO1_BASE_URL=https://api.contro1.com/api/centcom/v1
CONTRO1_WEBHOOK_SECRET=whsec_your_secret
PUBLIC_BASE_URL=https://your-connector.example.com

# Connector server
LISTENER_PORT=8091
CALLBACK_MAX_SKEW_SECONDS=300

# AWS Lambda MicroVMs
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/Contro1MicrovmLauncherRole
AWS_EXTERNAL_ID=contro1_customer_external_id

# Keep mock mode on until your AWS SDK/boto3 version exposes Lambda MicroVM APIs.
SIMULATE_AWS=true

# Policy defaults
ALLOWED_AGENT_IDS=agent-dev,agent-ci
ALLOWED_IMAGE_ARNS=arn:aws:lambda:us-east-1:123456789012:microvm-image:agent-sandbox
ALLOWED_EXECUTION_ROLE_ARNS=arn:aws:iam::123456789012:role/MicrovmSandboxExecutionRole
PRODUCTION_EXECUTION_ROLE_ARNS=arn:aws:iam::123456789012:role/MicrovmProductionExecutionRole
MAX_AUTO_APPROVE_DURATION_SECONDS=1800
MAX_TOKEN_TTL_SECONDS=900
ALLOWED_TOKEN_PORTS=8080,8443
DEFAULT_REQUIRED_ROLE=security
DEFAULT_SLA_MINUTES=10
